# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here

# development | production
FLASK_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default): leave blank or set path
# PostgreSQL example: postgresql://user:password@localhost:5432/tfs
DATABASE_URL=sqlite:///tfs.db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
# [Session] Idle timeout in minutes (default: 15 min). Spec: 15-min idle, 8-hr absolute max.
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
# [Session] Absolute max session lifetime in hours (default: 8 hr).
JWT_SESSION_ABSOLUTE_MAX_HOURS=8
# [Security] bcrypt work factor. MUST be >= 12 in production. Higher = slower hashing.
BCRYPT_LOG_ROUNDS=12

# ───Encryption─────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-encryption-key-here

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
# Max file size in bytes (default: 100 MB)
MAX_CONTENT_LENGTH=104857600

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Must match your frontend URL exactly
FRONTEND_URL=http://localhost:5173
